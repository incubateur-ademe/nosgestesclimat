actions . alimentation . manger local et de saison:
  titre: Manger local et de saison
  meta:
    id: 413f99ad-f198-4f6b-acd8-53f644b9d11e
  applicable si:
    une de ces conditions:
      - utilisateur . consommation de saison = "jamais"
      - utilisateur . consommation de saison = "parfois"
      - utilisateur . consommation locale = "jamais"
      - utilisateur . consommation locale = "parfois"
  formule: alimentation - nouveau régime
  avec:
    nouveau régime:
      valeur: alimentation
      contexte:
        alimentation . de saison . consommation: "'oui toujours'"
        alimentation . local . consommation: "'oui toujours'"

