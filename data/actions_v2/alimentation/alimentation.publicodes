actions . alimentation . réduire boissons sucrées:
  titre: Réduire sa consommation de boissons sucrées
  meta:
    id: 4425f8fb-a40c-41ed-9f38-294d71d598ab
  applicable si: utilisateur . consommation boissons sucrées hebdo > 0
