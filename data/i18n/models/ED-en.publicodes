transport . train . km:
  question: null
  formule: trajet freq * trajet km
  avec:
    trajet freq:
      formule:
        variations:
          - si: possibilités = 'rarement'
            alors: 2
          - si: possibilités = 'occasionnellement'
            alors: 8
          - si: possibilités = 'régulièrement'
            alors: 20
          - si: possibilités = 'très souvent'
            alors: 60
    trajet freq . possibilités:
      question: |
        You’re taking the train...
      une possibilité:
        - rarement
        - occasionnellement
        - régulièrement
        - très souvent
    trajet freq . possibilités . rarement:
      titre: Rarely (once or twice a year)
    trajet freq . possibilités . occasionnellement:
      titre: Occasionally (a few times a year)
    trajet freq . possibilités . régulièrement:
      titre: Frequently (at least once a month)
    trajet freq . possibilités . très souvent:
      titre: Almost every day (several times a week)
    trajet km:
      formule:
        variations:
          - si: possibilités = 'court'
            alors: 50
          - si: possibilités = 'moyen'
            alors: 300
          - si: possibilités = 'long'
            alors: 600
    trajet km . possibilités:
      question: |
        Your train journeys are usually:
      description: |
        Choose the answer that best reflects the average distance of your journeys.
      une possibilité:
        - court
        - moyen
        - long
    trajet km . possibilités . court:
      titre: Short films (less than an hour)
    trajet km . possibilités . moyen:
      titre: Moderate (between 1 and 3 hours)
    trajet km . possibilités . long:
      titre: Long (over 3 hours)
