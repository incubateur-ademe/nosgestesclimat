params:
  code: ED
  nom: School
  gentilé: school-related
logement . type:
  question: Tell us about your accommodation. Where do you usually live during the school year?
  description: |
    If you move between several homes, please choose one to use for your answers.
  une possibilité:
    - maison
    - appartement
    - internat
  avec:
    internat:
      titre: At boarding school
logement . type . maison:
  titre: In a house
logement . type . appartement:
  titre: In a flat
logement . propriétaire:
  question: null
logement . habitants:
  question: How many people live in this property (including you)?
  description: |
    This figure will enable us to break down the property’s carbon footprint.
logement . surface:
  question: null
  formule:
    variations:
      - si: surface . possibilités = 'studio'
        alors: 30 m2
      - si: surface . possibilités = 'une chambre'
        alors: 50 m2
      - si: surface . possibilités = 'deux chambres'
        alors: 70 m2
      - si: surface . possibilités = 'trois chambres'
        alors: 100 m2
      - si: surface . possibilités = 'quatre chambres'
        alors: 120 m2
      - si: surface . possibilités = 'plus de 4 chambres'
        alors: 150 m2
  par défaut: surface par défaut
  avec:
    surface par défaut:
      arrondi: 1 décimale
      formule:
        variations:
          - si: logement . est un appartement
            alors: parc français . surface moyenne appartement
          - si: logement . est une maison
            alors: parc français . surface moyenne maison
          - si:
              toutes ces conditions:
                - est défini: logement . type
                - logement . type = 'internat'
                - logement . type moyen = non
            alors: 12 m2
          - sinon: parc français . surface moyenne
    possibilités:
      question: How many bedrooms are there in your house?
      description: This information will help us estimate the floor area of the property where you live.
      une possibilité:
        - studio
        - une chambre
        - deux chambres
        - trois chambres
        - quatre chambres
        - plus de 4 chambres
    possibilités . studio:
      titre: Studio flat (1 room)
    possibilités . une chambre:
      titre: 1 bedroom
    possibilités . deux chambres:
      titre: 2 bedrooms
    possibilités . trois chambres:
      titre: 3 bedrooms
    possibilités . quatre chambres:
      titre: 4 bedrooms
    possibilités . plus de 4 chambres:
      titre: More than 4 bedrooms
logement . âge:
  question: null
logement . construction . travaux de rénovation:
  question: null
