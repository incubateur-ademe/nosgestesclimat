params:
  code: ED
  nom: School
  gentilé: school
logement . type:
  question: Describe your accommodation. Where do you live most often during the school year?
  description: |
    If you alternate between several homes, choose one for your answers.
  une possibilité:
    - maison
    - appartement
    - internat
  avec:
    internat:
      titre: À l’internat
logement . type . maison:
  titre: In a house
logement . type . appartement:
  titre: In a flat
logement . propriétaire:
  question: null
logement . habitants:
  question: How many people live in this home (including you)?
  description: |
    This figure will enable us to distribute the housing footprint.
  suggestions:
    two people: 2
    three people: 3
    Four people: 4
    five people: 5
logement . surface:
  question: null
  formule:
    variations:
      - si: surface . possibilités = 'studio'
        alors: 30 m2
      - si: surface . possibilités = 'une chambre'
        alors: 50 m2
      - si: surface . possibilités = 'deux chambres'
        alors: 70 m2
      - si: surface . possibilités = 'trois chambres'
        alors: 100 m2
      - si: surface . possibilités = 'quatre chambres'
        alors: 120 m2
      - si: surface . possibilités = 'plus de 4 chambres'
        alors: 150 m2
  par défaut: surface par défaut
  avec:
    surface par défaut:
      arrondi: 1 décimale
      formule:
        variations:
          - si: logement . est un appartement
            alors: parc français . surface moyenne appartement
          - si: logement . est une maison
            alors: parc français . surface moyenne maison
          - si:
              toutes ces conditions:
                - est défini: logement . type
                - logement . type = 'internat'
                - logement . type moyen = non
            alors: 12 m2
          - sinon: parc français . surface moyenne
    possibilités:
      question: Combien y-a-t-il de chambres chez toi ?
      description: Cette indication va nous aider à estimer la surface du logement où tu vis.
      une possibilité:
        - studio
        - une chambre
        - deux chambres
        - trois chambres
        - quatre chambres
        - plus de 4 chambres
    possibilités . studio:
      titre: Studio (1 pièce)
    possibilités . une chambre:
      titre: 1 chambre
    possibilités . deux chambres:
      titre: 2 chambres
    possibilités . trois chambres:
      titre: 3 chambres
    possibilités . quatre chambres:
      titre: 4 chambres
    possibilités . plus de 4 chambres:
      titre: Plus de 4 chambres
logement . âge:
  question: null
logement . construction . travaux de rénovation:
  question: null
logement . climatisation . présent:
  question: Do you have an air conditioning system at home?
  avec:
    oui et utilisation:
      titre: Oui, et on l'utilise parfois
    oui sans utilisation:
      titre: Oui, mais on ne l'utilise pas
    pas de climatiseurs:
      titre: Non, pas à ma connaissance
logement . climatisation . rappel kWh:
  formule: non
logement . piscine . type:
  question: Do you have a swimming pool?
logement . piscine . surface:
  question: null
logement . chauffage . mode:
  question: null
  par défaut: "'individuel'"
logement . chauffage . principal:
  question: How is your home heated?
  applicable si: oui
  description: null
  une possibilité:
    - électricité
    - PAC air eau
    - gaz
    - fioul
    - bois
  avec:
    électricité:
      titre: Avec des radiateurs électriques ⚡️
    PAC air eau:
      titre: Avec une pompe à chaleur
    gaz:
      titre: Au gaz 🔥
    fioul:
      titre: Au fioul 🛢️
    bois:
      titre: Avec une chaudière à bois ou à granulés 🪵
logement . chauffage . principal . ecs:
  question: null
  par défaut: "'identique'"
logement . chauffage . appoint:
  question: Do you also have a fireplace or stove in your home?
  applicable si: oui
  non applicable si: non
  mosaique:
    type: selection
    options:
      - bois . présent
    option aucun: no, there isn't any
  avec:
    électricité:
      titre: Radiateurs électriques
    électricité . présent:
      question: null
    bois:
      titre: Oui, il y a une cheminée ou un poêle
    bois . présent:
      question: Utilisez-vous du bois pour de l'appoint au sein de votre logement ?
    bouteille gaz cuisson:
      titre: Bouteille de gaz pour la cuisson
    bouteille gaz cuisson . présent:
      question: null
logement . chauffage . saisie précision consommation:
  question: null
logement . chauffage . précision consommation . ressenti:
  question: null
