    facteur hiver: 1.62
    facteur surtout hiver: 1.41
    facteur été: 0
    facteur surtout été: 0.13
  formule:
    variations:
      - si: saison = 'hiver'
        alors: facteur hiver
      - si: saison = 'surtout hiver'
        alors: facteur surtout hiver
      - si: saison = 'été'
        alors: facteur été
