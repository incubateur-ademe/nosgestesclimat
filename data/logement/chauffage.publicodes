      - toutes ces conditions:
          - chauffage . principal = "bois"
          - chauffage . principal . ecs = "identique"
      - toutes ces conditions:
          - chauffage . collectif = "bois"
          - chauffage . collectif . ecs = "source collectif"

logement . chauffage . bois . système:
  applicable si:
    toutes ces conditions:
      - est défini: bois . présent
      - bois . présent
  mosaique:
    type: selection
    options:
